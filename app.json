{
  "expo": {
    "name": "rehabtrace_app",
    "slug": "rehabtrace_app",
    "scheme": "rehabtrace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",

      [ "expo-image-picker", {
        "photosPermission": "Appen trenger tilgang til bildene dine for å dokumentere skader.",
        "cameraPermission": "Appen trenger tilgang til kamera for å ta bilder av skaden "
      }

      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Appen trenger posisjonen din for å logge hvor skaden oppstod."
        }
      ]
    ]
  }
}
